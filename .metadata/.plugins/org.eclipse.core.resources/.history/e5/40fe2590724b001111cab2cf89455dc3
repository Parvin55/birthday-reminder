<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Birthday Reminder</title>

<style>
    body {
        font-family: Arial;
        margin: 0;
        background: #f5f6fa;
    }

    .container {
        max-width: 600px;
        margin: auto;
        padding: 15px;
    }

    h1 {
        text-align: center;
        font-size: 22px;
        margin-bottom: 15px;
        color: #2c3e50;
    }

    .card {
        background: white;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 15px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    }

    input, textarea {
        width: 100%;
        padding: 12px;
        margin: 6px 0;
        border-radius: 8px;
        border: 1px solid #ddd;
        font-size: 14px;
    }

    button {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 15px;
    }

    .save-btn {
        background: #2ecc71;
        color: white;
    }

    h2 {
        font-size: 18px;
        text-align: center;
        margin-bottom: 10px;
    }

    /* CARD STYLE FOR PEOPLE */
    .person-card {
        background: white;
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 10px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.08);
    }

    .name {
        font-weight: bold;
        font-size: 16px;
        color: #2c3e50;
    }

    .meta {
        font-size: 13px;
        color: #555;
        margin-top: 4px;
        word-break: break-word;
    }

    .actions {
        margin-top: 10px;
        display: flex;
        justify-content: space-between;
    }

    .edit {
        color: #3498db;
        text-decoration: none;
        font-size: 14px;
    }

    .delete {
        color: #e74c3c;
        text-decoration: none;
        font-size: 14px;
    }
</style>

</head>

<body>

<div class="container">

<h1>🎉 Birthday Reminder</h1>

<!-- FORM -->
<div class="card">
    <form action="/save" method="post" th:object="${birthday}">

        <input type="hidden" th:field="*{id}" />

        <input type="text" th:field="*{name}" placeholder="Name" required>

        <input type="email" th:field="*{email}" placeholder="Email" required>

        <input type="date" th:field="*{birthday}" required>

        <textarea th:field="*{message}" placeholder="Message"></textarea>

        <button class="save-btn" type="submit">Save</button>

    </form>
</div>

<!-- LIST -->
<h2>Saved Birthdays</h2>

<div th:each="p : ${birthdays}" class="person-card">

    <div class="name" th:text="${p.name}"></div>

    <div class="meta">
        📧 <span th:text="${p.email}"></span>
    </div>

    <div class="meta">
        🎂 <span th:text="${p.birthday}"></span>
    </div>

    <div class="meta" th:text="${p.message}"></div>

    <div class="actions">
        <a class="edit" th:href="@{'/edit/' + ${p.id}}">Edit</a>
        <a class="delete" th:href="@{'/delete/' + ${p.id}}">Delete</a>
    </div>

</div>

</div>

</body>
</html>